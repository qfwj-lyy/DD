[sub_resource type="GDScript" id="GDScript_d84jm"]
script/source = "extends Buff


func _ready() -> void:
	connect(\"reparented_to_buff_manager\",display_sentence)
func display_sentence():
	G.D.display_sentence(\"心情值突破20，获得心情20buff：增加1手牌上限\")
	
	
func execute():
	G.P.add_hand_card_amount_limit(1)
	
func die():
	G.D.display_sentence(\"失去心情20buff：增加1手牌上限\")
	G.P.add_hand_card_amount_limit(-1)
	reparent(G.P.mood_buffs)
	G.P.mood_buffs.mood_20_buff = self
"


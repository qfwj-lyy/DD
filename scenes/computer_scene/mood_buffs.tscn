[sub_resource type="GDScript" id="GDScript_kbgpp"]
script/source = "extends Buff

func _ready() -> void:
	connect(\"reparented_to_buff_manager\",display_sentence)
func display_sentence():
	G.D.display_sentence(\"心情值突破60，获得心情60buff：商店可以刷出稀有卡片\")
	
func execute():
	G.M.current_scene.store_scene.can_get_ai_and_party = true

func die():
	G.D.display_sentence(\"失去心情60buff：商店可以刷出稀有卡片\")
	G.M.current_scene.store_scene.can_get_ai_and_party = false
	reparent(G.P.mood_buffs)
	G.P.mood_buffs.mood_60_buff = self
"


[sub_resource type="GDScript" id="GDScript_t7krb"]
script/source = "extends Control

@onready var small_input_area: Control = $SmallInputArea

var is_open := false

func _input(event: InputEvent) -> void:
	if not is_open:
		return
	if event.is_action_released(\"LeftMouseDown\"):
		var p = get_global_mouse_position()
		if p.x < small_input_area.position.x:
			get_viewport().set_input_as_handled()
		elif p.x > small_input_area.position.x + small_input_area.size.x:
			get_viewport().set_input_as_handled()
		elif p.y > small_input_area.position.y + small_input_area.size.y:
			get_viewport().set_input_as_handled()
		elif p.y < small_input_area.position.y:
			get_viewport().set_input_as_handled()
		else:
			clear()
	elif event is InputEventMouseButton and event.pressed and event.button_index == MouseButton.MOUSE_BUTTON_LEFT:
		var p = get_global_mouse_position()
		if p.x < small_input_area.position.x:
			get_viewport().set_input_as_handled()
		elif p.x > small_input_area.position.x + small_input_area.size.x:
			get_viewport().set_input_as_handled()
		elif p.y > small_input_area.position.y + small_input_area.size.y:
			get_viewport().set_input_as_handled()
		elif p.y < small_input_area.position.y:
			get_viewport().set_input_as_handled()
		else:
			clear()
	else:
		get_viewport().set_input_as_handled()
			
func clear():
	for point in small_input_area.get_children():
		point.queue_free()
	small_input_area.size = Vector2.ZERO
	small_input_area.position = Vector2.ZERO
	is_open = false
"


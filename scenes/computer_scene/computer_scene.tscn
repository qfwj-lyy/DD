[sub_resource type="GDScript" id="GDScript_d84jm"]
script/source = "extends Control
@onready var get_deposit_label: Label = $GetDepositLabel
@onready var deliver_project_label: Label = $DeliverProjectLabel
@onready var project_failure_label: Label = $ProjectFailureLabel

@onready var deliver_anim: AnimationPlayer = $DeliverProjectLabel/DeliverAnim
@onready var fail_anim: AnimationPlayer = $ProjectFailureLabel/FailAnim

func display():
	get_deposit_label.text = \"获得存款：\" + str(G.P.current_project.deposit_reward)
	show()
	deliver_anim.play(\"deliver_anim\")
	project_failure_label.hide()
	
	await get_tree().create_timer(5).timeout
	hide()
	
func display_failure():
	get_deposit_label.text = \"存款惩罚：\" + str(G.P.current_project.deposit_reward)
	show()
	deliver_project_label.hide()
	fail_anim.play(\"deliver_anim\")
	await get_tree().create_timer(5).timeout
	hide()
	
func _ready() -> void:
	visible = false
"

